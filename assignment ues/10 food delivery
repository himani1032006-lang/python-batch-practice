while True:
    print("\n----- Food Menu -----")
    print("1. Pizza")
    print("2. Burger")
    print("3. Fries")
    print("4. Exit")

    choice = int(input("Enter your choice: "))

    if choice == 1:
        print("You selected Pizza.")
    elif choice == 2:
        print("You selected Burger.")
    elif choice == 3:
        print("You selected Fries.")
    elif choice == 4:
        print("Thank you for using the Food Delivery App!")
        break
    else:
        print("Invalid choice! Please try again.")